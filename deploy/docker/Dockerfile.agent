FROM golang:1.22-bookworm AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags "-s -w" -o /hookmon-agent ./cmd/hookmon-agent

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /hookmon-agent /usr/bin/hookmon-agent

RUN mkdir -p /etc/hookmon /var/log/hookmon

# Agent needs elevated privileges for eBPF
# Run with: --privileged or --cap-add=SYS_ADMIN --cap-add=BPF
ENTRYPOINT ["/usr/bin/hookmon-agent"]
CMD ["--config", "/etc/hookmon/agent.yaml"]
